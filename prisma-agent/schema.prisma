// Prisma schema for the Venue Agent product.
//
// Lives in the `agent_dev` PostgreSQL schema on the same Render Postgres
// instance as the agency tables (which live in `public`). Fully isolated:
// the agent product can iterate without risk to production agency ops.
//
// To migrate: prisma db push --schema=prisma-agent/schema.prisma
// Connection URL must include ?schema=agent_dev (set via DATABASE_URL_AGENT
// env var).

generator agentClient {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/agent-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_AGENT")
}

// =====================================================================
// Venue Agent product (started 2026-04-29)
// Multi-tenant SaaS layered on top of brightears.io.
// All Agent* tables are isolated from the agency schema (Venue / Artist /
// VenueAssignment / VenueFeedback) — the agency keeps running unchanged
// while the agent product develops in parallel. Migration to a unified
// schema is a Phase 2 decision once the product is stable.
// =====================================================================

enum AgentTenantTier {
  STARTER         // $25/mo, 1 venue, 1M tokens
  PRO             // $75/mo, 1 venue, 10M tokens
  GROUP           // $200/mo, up to 5 venues, 25M tokens
  ENTERPRISE      // custom, unlimited venues
  BETA            // free internal/agency-customer beta
}

enum AgentTenantStatus {
  TRIAL           // 14-day free trial, no card
  ACTIVE          // paying or beta
  PAST_DUE        // failed payment, soft-blocked
  CANCELED        // explicit cancel, retains data 90 days then purged
}

enum AgentMemberRole {
  OWNER           // billing, can invite, can delete tenant
  CORPORATE_HEAD  // sees all venues in tenant (group tier)
  MANAGER         // sees + edits one venue
  ASSISTANT       // limited write, can run agent, can't change billing
}

enum AgentSlotStatus {
  PLANNED         // future slot, awaiting DJ confirm
  CONFIRMED       // DJ confirmed
  COMPLETED       // shift ended, feedback expected
  CANCELED        // shift canceled (no-DJ-needed event, closure, etc.)
  NO_DJ           // intentional no-DJ flag (private event, etc.)
}

enum AgentAutopilotMode {
  COPILOT         // all external sends draft + manager approves
  HYBRID          // Tier 1 auto-act, Tier 2 draft + approve  (default)
  AUTOPILOT       // agent acts on Tier 2 too (escape hatch for power users)
}

model AgentTenant {
  id                 String              @id @default(uuid())
  name               String              // "Centara Hotels Group" / "Sato San Pte Ltd"
  slug               String              @unique // "centara" — used in URL paths and public refs
  tier               AgentTenantTier     @default(STARTER)
  status             AgentTenantStatus   @default(TRIAL)
  autopilotMode      AgentAutopilotMode  @default(HYBRID)

  // Branding (used in white-label Phase 2 — present on every tenant from day 1
  // so existing data is white-label-ready when we add the UI)
  brandName          String?
  brandLogoUrl       String?
  brandPrimaryColor  String?             // hex
  brandAccentColor   String?             // hex
  customDomain       String?             // future white-label, ie agent.somehotel.com

  // Stripe billing
  stripeCustomerId       String?         @unique
  stripeSubscriptionId   String?         @unique
  monthlyTokenAllowance  Int             @default(1000000)
  monthlyTokenUsed       Int             @default(0)
  topUpCreditsRemaining  Int             @default(0)
  billingCycleResetsAt   DateTime?

  // Timestamps
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  trialEndsAt        DateTime?

  members            AgentMember[]
  venues             AgentVenue[]
  artists            AgentArtist[]
  auditLog           AgentAuditLog[]

  @@index([status])
  @@index([slug])
}

model AgentMember {
  id            String           @id @default(uuid())
  tenantId      String
  clerkUserId   String           // links to Clerk
  email         String
  displayName   String?
  role          AgentMemberRole
  venueScope    String[]         @default([]) // empty = all tenant venues; otherwise list of venue ids
  invitedAt     DateTime         @default(now())
  acceptedAt    DateTime?

  tenant        AgentTenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, clerkUserId])
  @@index([clerkUserId])
}

model AgentVenue {
  id                String           @id @default(uuid())
  tenantId          String
  name              String           // "Sato San Rooftop", "TENKU 33"
  timezone          String           @default("Asia/Bangkok")
  operatingHours    Json?            // { mon: ["18:00","00:00"], tue: ... }
  genreNotes        String?          // "deep house, lounge, no high-energy"
  djRateCeiling     Int?             // baht/hr ceiling, used in agent autopilot decisions
  lineChannelId     String?          // per-venue LINE channel (for tenant-scoped DJ groups)
  lineChannelSecret String?
  lineAccessToken   String?
  notes             String?

  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  tenant            AgentTenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  scheduleSlots     AgentScheduleSlot[]
  invoices          AgentInvoice[]

  @@index([tenantId])
}

model AgentArtist {
  id            String           @id @default(uuid())
  tenantId      String
  stageName     String
  realName      String?
  genres        String[]         @default([])
  hourlyRate    Int?             // baht
  lineGroupId   String?          // tenant's 1:1 channel for this DJ
  email         String?
  phone         String?
  notes         String?
  active        Boolean          @default(true)

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  tenant        AgentTenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  scheduleSlots AgentScheduleSlot[]

  @@unique([tenantId, stageName])
  @@index([tenantId])
}

model AgentScheduleSlot {
  id              String            @id @default(uuid())
  tenantId        String            // denormalized for tenant-scoped queries
  venueId         String
  artistId        String?           // null = empty slot or specialEvent
  date            DateTime          // date-only, venue tz
  slot            String?           // "Early", "Late", "main"
  startTime       String            // "18:00"
  endTime         String            // "21:00"
  status          AgentSlotStatus   @default(PLANNED)
  specialEvent    String?           // "Closed", "Private Event", etc.
  notes           String?

  // Confirmation tracking
  djReminderSentAt    DateTime?
  djConfirmedAt       DateTime?
  feedbackRequestSentAt DateTime?

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  venue           AgentVenue        @relation(fields: [venueId], references: [id], onDelete: Cascade)
  artist          AgentArtist?      @relation(fields: [artistId], references: [id], onDelete: SetNull)
  feedback        AgentFeedback?

  @@unique([venueId, date, slot])
  @@index([tenantId, date])
  @@index([artistId])
}

model AgentFeedback {
  id              String            @id @default(uuid())
  scheduleSlotId  String            @unique
  tenantId        String            // denormalized
  overallRating   Int               // 1-5
  notes           String?
  submittedBy     String?
  submittedAt     DateTime          @default(now())

  scheduleSlot    AgentScheduleSlot @relation(fields: [scheduleSlotId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model AgentInvoice {
  id              String            @id @default(uuid())
  tenantId        String            // denormalized
  venueId         String
  invoiceNumber   String
  periodStart     DateTime
  periodEnd       DateTime
  subtotal        Decimal           @db.Decimal(12, 2)
  vat             Decimal           @db.Decimal(12, 2)
  withholdingTax  Decimal           @db.Decimal(12, 2)
  total           Decimal           @db.Decimal(12, 2)
  currency        String            @default("THB")
  pdfUrl          String?
  sentAt          DateTime?
  paidAt          DateTime?

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  venue           AgentVenue        @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
}

model AgentAuditLog {
  id              String            @id @default(uuid())
  tenantId        String
  actorClerkUserId String?          // null = system / agent autonomous
  actorIsAgent    Boolean           @default(false)
  action          String            // "schedule.update", "dj.message", "invoice.send"
  resourceType    String?           // "AgentScheduleSlot", "AgentArtist", etc.
  resourceId      String?
  details         Json?
  occurredAt      DateTime          @default(now())

  tenant          AgentTenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, occurredAt])
}

// LLM usage ledger — every agent call logs here for billing + observability.
model AgentLlmUsage {
  id              String            @id @default(uuid())
  tenantId        String
  model           String            // "qwen3", "deepseek-v4", "claude-sonnet-4-6"
  provider        String            // "openrouter", "anthropic"
  inputTokens     Int
  outputTokens    Int
  costUsd         Decimal           @db.Decimal(12, 6)  // raw cost
  taskType        String?           // "chat", "draft_email", "schedule_suggest"
  durationMs      Int?
  occurredAt      DateTime          @default(now())

  @@index([tenantId, occurredAt])
}
